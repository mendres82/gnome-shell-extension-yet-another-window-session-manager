[Desktop Entry]
Version=1.0
Name=${appName}
Comment=User-created launcher for ${appName}
Type=Application
Exec=${commandLine}
Icon=${icon}
Terminal=false
StartupWMClass=${wmClass}
# If the former does not work, use the below line instead.
# If it still does not work, please fill an issue at:
# https://github.com/mendres82/gnome-shell-extension-yet-another-window-session-manager/issues
# StartupWMClass=${wmClassInstance}
