msgstr "Damit diese Funktion funktioniert, siehe: <a href='https://github.com/mendres82/gnome-shell-extension-yet-another-window-session-manager#how-to-make-close-by-rules-work'>So funktioniert „Nach Regeln schließen“</a>."

#: ui/prefs-gtk4.ui
msgid "Restore sessions"
msgstr "Sitzungen wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Restore previous apps and windows at startup"
msgstr "Vorherige Anwendungen und Fenster beim Start wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Install ~/.config/autostart/_yawsm-restore-previous-session.desktop if enabled."
msgstr "Bei Aktivierung ~/.config/autostart/_yawsm-restore-previous-session.desktop installieren."

#: ui/prefs-gtk4.ui
msgid "Restore delay([0, 3600]s)"
msgstr "Verzögerung beim Wiederherstellen ([0, 3600] s)"

#: ui/prefs-gtk4.ui
msgid "5 by default."
msgstr "Standardmäßig 5."

#: ui/prefs-gtk4.ui
msgid "Restore selected session at startup"
msgstr "Ausgewählte Sitzung beim Start wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Install ~/.config/autostart/_gnome-shell-extension-yet-another-window-session-manager.desktop if enabled."
msgstr "Bei Aktivierung ~/.config/autostart/_gnome-shell-extension-yet-another-window-session-manager.desktop installieren."

#: ui/prefs-gtk4.ui
msgid "Restore at startup without asking"
msgstr "Beim Start ohne Nachfrage wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Timer on the autostart dialog([0, 3600]s)"
msgstr "Timer im Autostart-Dialog ([0, 3600] s)"

#: ui/prefs-gtk4.ui
msgid "10 by default."
msgstr "Standardmäßig 10."

#: ui/prefs-gtk4.ui
msgid "Restore applications interval([0, 300000]ms)"
msgstr "Intervall beim Wiederherstellen von Anwendungen ([0, 300000] ms)"

#: ui/prefs-gtk4.ui
msgid "0 by default. There's no need to set this option normally, unless the process of restoring session is too fast to freeze the system, for example."
msgstr "Standardmäßig 0. Diese Option muss normalerweise nicht gesetzt werden, es sei denn, der Wiederherstellungsvorgang ist so schnell, dass das System einfriert."

#: ui/prefs-gtk4.ui
msgid "Autostart delay([0, 3600]s)"
msgstr "Autostart-Verzögerung ([0, 3600] s)"

#: ui/prefs-gtk4.ui
msgid "5 by default. Delay before restoring session at startup or the previous session. If the delay is too short, the computer might freeze."
msgstr "Standardmäßig 5. Verzögerung vor dem Wiederherstellen der Sitzung beim Start oder der vorherigen Sitzung. Ist die Verzögerung zu kurz, kann der Computer einfrieren."

#: ui/prefs-gtk4.ui
msgid "Restore window tiling"
msgstr "Fensterkacheln wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Raise windows together"
msgstr "Fenster gemeinsam nach vorne holen"

#: ui/prefs-gtk4.ui
msgid "Restore windows states after Gnome Shell restarts"
msgstr "Fensterzustände nach GNOME-Shell-Neustart wiederherstellen"

#: ui/prefs-gtk4.ui
msgid "Only enabled on X11, since Wayland doesn't support restart Gnome Shell via `Alt+F2 then type r` or `killall -3 gnome-shell`."
msgstr "Nur unter X11 verfügbar, da Wayland keinen GNOME-Shell-Neustart über Alt+F2, dann r oder killall -3 gnome-shell unterstützt."

